# Supabase credentials
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email (Resend) - optional. Without RESEND_API_KEY welcome emails are skipped.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=STS <hello@yourdomain.com>

# Stripe credentials
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRICE_ID=your_stripe_price_id
PUBLIC_BASE_URL=http://localhost:5173

# Research bundle delivery (Supabase Storage)
# Create a bucket named "downloads" in your Supabase project (set to private).
# Upload the bundle file to that bucket, then set the path here.
DOWNLOAD_BUCKET=downloads
DOWNLOAD_BUNDLE_PATH=research-bundle-v1.zip