# Supabase credentials
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email (Resend) - optional. Without RESEND_API_KEY welcome emails are skipped.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=STS <hello@yourdomain.com>

# Stripe credentials
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRICE_ID=your_stripe_price_id
STRIPE_PRICE_ID_STANDARD=your_standard_edition_price_id
STRIPE_PRICE_ID_AUTHORS=your_authors_edition_price_id
PUBLIC_BASE_URL=http://localhost:5173

# Research bundle delivery (Supabase Storage)
# Create a bucket named "downloads" in your Supabase project (set to private).
# Upload the bundle file to that bucket, then set the path here.
DOWNLOAD_BUCKET=downloads
DOWNLOAD_BUNDLE_PATH=research-bundle-v1.zip

# Password gate for /book. Server-only — do NOT prefix with PUBLIC_, the
# check happens server-side. Sent to customers in the fulfillment email.
# Also set this in your Cloudflare Pages dashboard env vars before deploy.
BOOK_ACCESS_PASSWORD=your_book_password
# OPTIONAL, local/testing only — an email allowed to repeat-purchase the same
# edition; its prior preorder row is deleted before each new insert. Leave
# unset in production so no address can ever trigger that delete path.
# TEST_REPEAT_PURCHASE_EMAIL=you@example.com
